# ─────────────────────────────────────────────────────────────
#  Orael — Environment Configuration
# ─────────────────────────────────────────────────────────────

# ─── Telegram Bot ─────────────────────────────────────────────
# Get from @BotFather
BOT_TOKEN=

# ─── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
DOMAIN=https://yourdomain.com

# ─── Admin ────────────────────────────────────────────────────
# Comma-separated Telegram user IDs who have FULL admin access.
# Find your ID by messaging @userinfobot on Telegram.
# Example: ADMIN_IDS=123456789,987654321
ADMIN_IDS=

# ─── Adsgram (Rewarded Ads) ───────────────────────────────────
# From https://partner.adsgram.ai
VITE_ADSGRAM_BLOCK_ID=35273
VITE_ADSGRAM_TASK_BLOCK_ID=task-35279
ADSGRAM_SECRET=

# ─── Flutterwave (Payouts — Bank Transfer + Airtime) ──────────
# Get from https://dashboard.flutterwave.com/dashboard/settings/apis
# SECRET_KEY: required for all server-side API calls (Bearer auth)
# SECRET_HASH: set on dashboard → Settings → Webhooks; Flutterwave sends it in verif-hash header
# PUBLIC_KEY: only needed if you add frontend card payments later (not needed for payouts)
# ENCRYPTION_KEY: only needed for direct card charge (not needed for payouts)
FLW_SECRET_KEY=
FLW_SECRET_HASH=
FLW_PUBLIC_KEY=
FLW_ENCRYPTION_KEY=

# ─── Withdrawal Limits (KYC tiers — customizable) ─────────────
# Daily withdrawal cap per user (in ORL)
MAX_DAILY_WITHDRAWAL_ORL=500000
# Monthly withdrawal cap per user (in ORL)
MAX_MONTHLY_WITHDRAWAL_ORL=5000000
# Maximum single withdrawal amount (in ORL)
MAX_SINGLE_WITHDRAWAL_ORL=200000
