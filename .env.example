# ─────────────────────────────────────────────────────────────
#  Orael — Environment Configuration (EXAMPLE)
#  Copy to `.env` and fill in real values. NEVER commit your real `.env`.
# ─────────────────────────────────────────────────────────────

# ── Telegram Bot ──
# Get from @BotFather (https://t.me/BotFather)
BOT_TOKEN=0000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Comma-separated list of Telegram user IDs who are super admins.
# Get your ID from @userinfobot.
ADMIN_IDS=

# ── Server ──
PORT=3000
NODE_ENV=production
# Your public domain (used for HTTPS redirect + Flutterwave callbacks)
DOMAIN=https://yorubacinemax.xyz

# ── DEV MODE (browser preview only — NEVER enable in production) ──
# When true, the server accepts X-Dev-Telegram-Id header in lieu of real
# Telegram initData HMAC. Leave FALSE in production.
DEV_MODE=false
VITE_DEV_MODE=false
VITE_DEV_USER_ID=999000001

# ── AdsGram (Rewarded video + Tasks) ──
# blockId format: digits for Reward ("123"), "task-<digits>" for Tasks.
# Get from https://partner.adsgram.ai
VITE_ADSGRAM_BLOCK_ID=
VITE_ADSGRAM_TASK_BLOCK_ID=
# Optional: small S2S bonus credited when AdsGram sends the reward callback.
# 0 = off (recommended — the client-side authed flow is the primary reward path).
ADSGRAM_S2S_BONUS_ORL=0

# ── Flutterwave (real NGN bank transfers + airtime) ──
# Get from https://dashboard.flutterwave.com/dashboard/settings/apis
FLW_SECRET_KEY=
FLW_SECRET_HASH=
FLW_PUBLIC_KEY=
FLW_ENCRYPTION_KEY=

# ── Withdrawal caps (ORL) ──
MAX_DAILY_WITHDRAWAL_ORL=500000
MAX_MONTHLY_WITHDRAWAL_ORL=5000000
MAX_SINGLE_WITHDRAWAL_ORL=200000

# ── Cron leadership (multi-replica Docker only) ──
# Set to "true" on EXACTLY ONE app replica. "false" on all others.
# Default: true (single-replica).
CRON_LEADER=true

# ── Production scale (PostgreSQL + Redis — see SCALING.md) ──
# Leave unset to use the default SQLite (data/orael.db).
# DATABASE_URL=postgresql://orael:password@db:5432/orael
# REDIS_URL=redis://redis:6379

# ── PostgreSQL (only if using docker-compose.prod.yml) ──
POSTGRES_PASSWORD=change_me_in_prod
