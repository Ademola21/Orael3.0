# ─────────────────────────────────────────────────────────────
#  Orael — .gitignore
# ─────────────────────────────────────────────────────────────

# Dependencies
node_modules/
bun.lock
package-lock.json

# Build output
dist/
.next/
.cache/

# Environment files (NEVER commit secrets)
.env
.env.*
!.env.example

# Database + user data (mounted as volumes in prod)
data/
*.db
*.db-wal
*.db-shm
data/backups/

# Logs
*.log
dev.log
server.log
npm-debug.log*
yarn-debug.log*
.pnpm-debug.log*

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# Docker (keep Dockerfile + compose, ignore runtime artifacts)
docker-data/

# Sandboxes / dev tooling (not part of the app)
.zscripts/
tool-results/
skills/
download/
upload/
mini-services/
examples/
prisma/
db/
worklog.md
.claude
.z-ai-config

# TypeScript
*.tsbuildinfo
next-env.d.ts
